#!/bin/sh
set -e

if ! docker compose exec -T frontend echo "ok" > /dev/null 2>&1; then
  echo "pre-commit: frontend container is not running - run 'make up' first"
  exit 1
fi

echo "pre-commit: formatting..."
docker compose exec -T frontend npm run format

git add -u

echo "pre-commit: linting..."
docker compose exec -T frontend npm run lint
