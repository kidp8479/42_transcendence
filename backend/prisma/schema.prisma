// Calendar 
//
//

model CalendarLabel {
  id                 String  @id @default(uuid())
  name               String
  color              Int
  projectId          String
  project            Project @relation(fields: [projectId], references: [id])
  events             CalendarEvent[]

  @@index([projectId])
}

model CalendarEvent {
  id                 String                    @id @default(uuid())
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  projectId          String
  title              String
  startAt            DateTime
  endAt              DateTime
  labelId            String
  label              CalendarLabel @relation(fields: [labelId], references: [id])
  description        String?
  notes              String?
  assignees          CalendarAssignee[]
}

model CalendarAssignee {
  id            String               @id @default(uuid())
  userId        String
  calId         String
  user          User                 @relation(fields: [userId], references: [id])
  calendarEvent CalendarEvent        @relation(fields: [calId], references: [id])
}

model EvaluationChecklistItem {
	
