// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// any "?" next to a field means it's optionnel

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// One User can be a member of many projects (via ProjectMember)
// One User has many ProjectMember rows - one per project they belong to
model User {
  id             String          @id @default(uuid())
  email          String          @unique // filled by the auth team via OAuth
  username       String          @unique
  avatarUrl      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  projectMembers ProjectMember[] // one User => many ProjectMember rows

  taskAssigned   TaskAssignee[]
  calAssigned    CalendarAssignee[]
}

// ProjectMember is the link between a User and a Project
// One row = one user belonging to one project
// One User can appear many times here (once per project)
// One Project can appear many times here (once per member)
model ProjectMember {
  id        String  @id @default(uuid())
  userId    String  // foreign key: which user
  projectId String  // foreign key: which project
  user      User    @relation(fields: [userId], references: [id])    // userId in this table = id in User
  project   Project @relation(fields: [projectId], references: [id]) // projectId in this table = id in Project
}

// One Project can have many members, tasks, events, blocks, and checklist items
model Project {
  id                       String                    @id @default(uuid())
  name                     String
  description              String?
  isCompleted              Boolean                   @default(false)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  members                  ProjectMember[]           // one Project => many ProjectMember rows
  tasks                    Task[]                    // one Project => many Task rows
  calendarEvents           CalendarEvent[]           // one Project => many CalendarEvent rows
  discoveryBlocks          DiscoveryBlock[]          // one Project => many DiscoveryBlock rows
  evaluationChecklistItems EvaluationChecklistItem[] // one Project => many EvaluationChecklistItem rows
}

// Task
//
//

model TaskCategory {
  id                 String  @id @default(uuid())
  name               String
  color              Int
  projectId          String
  project            Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

enum Status {
  TODO,
  IN_PROGRESS,
  REVIEW,
  COMPLETED
}

enum Priority {
  LOW,
  MEDIUM,
  HIGH
}

model Task {
  id                 String                    @id @default(uuid())
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  projectId          String
  title              String
  status             Status
  category           TaskCategory[]
  priority           Priority
  startAt            DateTime?
  endAt              DateTime?
  tag                String?
  description        String?
  notes              String?
  assignees          TaskAssignee[]
}

model TaskAssignee {
  id         String      @id @default(uuid())
  userId     String
  taskId     String
  user       User        @relation(fields: [userId], references: [id])
  task       Task        @relation(fields: [taskId], references: [id])
}

// Calendar 
//
//

model CalendarLabel {
  id                 String  @id @default(uuid())
  name               String
  color              Int
  projectId          String
  project            Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model CalendarEvent {
  id                 String
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  projectId          String
  title              String
  startAt            DateTime
  endAt              DateTime
  label              CalendarLabel[]
  description        String?
  notes              String?
  assignees          CalendarAssignee[]
}

model CalendarAssignee {
  id         String         @id @default(uuid())  userId     String
  calId      String
  user       User           @relation(fields: [userId], references: [id])
  task       Task           @relation(fields: [calId], references: [id])
}


