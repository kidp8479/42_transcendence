// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// any "?" next to a field means it's optional

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// One User can be a member of many projects (via ProjectMember)
// One User has many ProjectMember rows - one per project they belong to
model User {
  id               String             @id @default(uuid())
  email            String             @unique // filled by the auth team via OAuth
  emailVerified    Boolean            @default(false)
  username         String             @unique
  avatarUrl        String? // if null, the frontend generates an avatar from username initials (CSS only, no DB)
  campus           String? // ex: "42 Paris" - filled via OAuth, can be updated in settings
  twoFactorEnabled Boolean            @default(false) // toggled from the Security section in Settings
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  projectMembers   ProjectMember[] // one User => many ProjectMember rows
  taskAssigned     TaskAssignee[]
  calAssigned      CalendarAssignee[]
  notifications    Notification[] // one User => many Notifications rows
  authIdentities   AuthIdentity[]
  authSessions     AuthSession[]
  authTokens       AuthToken[]
  authEvents       AuthEvent[]
}

enum AuthProvider {
  LOCAL
  FORTY_TWO
  GOOGLE
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model AuthIdentity {
  id              String              @id @default(uuid())
  userId          String
  provider        AuthProvider
  providerSubject String
  email           String?
  emailVerified   Boolean             @default(false)
  displayName     String?
  profile         Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  password        PasswordCredential?

  @@unique([provider, providerSubject])
  @@index([userId])
  @@index([email])
}

model PasswordCredential {
  id                String       @id @default(uuid())
  identityId        String       @unique
  passwordHash      String
  passwordChangedAt DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  identity          AuthIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)
}

model AuthSession {
  id                   String       @id @default(uuid())
  userId               String
  tokenHash            String       @unique
  csrfTokenHash        String
  authenticationMethod AuthProvider
  assuranceLevel       Int          @default(1)
  authenticatedAt      DateTime     @default(now())
  lastSeenAt           DateTime     @default(now())
  idleExpiresAt        DateTime
  absoluteExpiresAt    DateTime
  revokedAt            DateTime?
  ipHash               String?
  userAgentHash        String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([idleExpiresAt])
  @@index([absoluteExpiresAt])
}

model OAuthTransaction {
  id                     String       @id @default(uuid())
  provider               AuthProvider
  stateHash              String       @unique
  codeVerifierCiphertext String?
  nonceHash              String?
  redirectUri            String
  returnTo               String
  createdAt              DateTime     @default(now())
  expiresAt              DateTime

  @@index([expiresAt])
}

model AuthToken {
  id         String        @id @default(uuid())
  userId     String
  type       AuthTokenType
  tokenHash  String        @unique
  createdAt  DateTime      @default(now())
  expiresAt  DateTime
  consumedAt DateTime?
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
}

model AuthEvent {
  id        String        @id @default(uuid())
  userId    String?
  eventType String
  provider  AuthProvider?
  sessionId String?
  ipHash    String?
  metadata  Json?
  createdAt DateTime      @default(now())
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

// no updatedAt: the only modification is marking as read (isRead), we don't need to track when that happened
model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  link      String? // optional: URL to the resource the notification refers to (ex: "/projects/abc/tasks")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade) // userId in this table = id in User

  @@index([userId])
}

// ProjectMember is the link between a User and a Project
// One row = one user belonging to one project
// One User can appear many times here (once per project)
// One Project can appear many times here (once per member)
model ProjectMember {
  id        String            @id @default(uuid())
  userId    String // foreign key: which user
  projectId String // foreign key: which project
  role      ProjectMemberRole @default(MEMBER) // per-project role, not global to the user (see enum below)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade) // userId in this table = id in User
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade) // projectId in this table = id in Project

  @@index([userId])
  @@index([projectId])
}

// ADMIN can edit/delete the project and its content, MEMBER has read/contribute access only.
// Who gets assigned ADMIN (ex: the project creator) is decided wherever ProjectMember rows
// get created (ProjectsService.create, ProjectMembersService.addMember) - not implemented yet.
enum ProjectMemberRole {
  ADMIN
  MEMBER
}

enum ProjectStatus {
  IN_PROGRESS
  REVIEW
  COMPLETED
}

// One Project can have many members, tasks, events, blocks, and checklist items
model Project {
  id                       String                    @id @default(uuid())
  name                     String
  description              String?
  status                   ProjectStatus             @default(IN_PROGRESS)
  deadline                 DateTime?
  isArchived               Boolean                   @default(false)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  members                  ProjectMember[] // one Project => many ProjectMember rows
  tasks                    Task[] // one Project => many Task rows
  taskCategories           TaskCategory[] // one Project => many TaskCategory rows
  calendarEvents           CalendarEvent[] // one Project => many CalendarEvent rows
  calendarCategories       CalendarCategory[] // one Project => many CalendarCategory rows
  discoveryBlocks          DiscoveryBlock[] // one Project => many DiscoveryBlock rows
  evaluationChecklistItems EvaluationChecklistItem[] // one Project => many EvaluationChecklistItem rows
}

// TASK
//    This configures the Task related tables: Task, TaskCategory, TaskAssignee
//
enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

// Every category of every task registered in the whole website.
// Linked by a single projectID value
model TaskCategory {
  id        String  @id @default(uuid())
  name      String
  color     Int
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([projectId])
}

// Every assignment Card/Member.
// Linked by userId and taskId (which contains a unique projectId value)
model TaskAssignee {
  id     String @id @default(uuid())
  userId String
  taskId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([userId])
  @@index([taskId])
}

// Every Task of every project
// Linked by a unique projectId value
model Task {
  id          String         @id @default(uuid())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  status      TaskStatus
  categoryId  String?
  category    TaskCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  rank        Int
  priority    TaskPriority
  startAt     DateTime?
  endAt       DateTime?
  description String?
  notes       String?
  assignees   TaskAssignee[]
  onCalendar  Boolean

  @@index([projectId])
  @@index([categoryId])
}

// CALENDAR
//    This configures the Calendar related tables: CalendarEvent, CalendarCategory, CalendarAssignee
//

// Every category of every calendar entry registered in the whole website.
// Linked by a single projectID value
model CalendarCategory {
  id        String          @id @default(uuid())
  name      String
  color     Int
  projectId String
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events    CalendarEvent[]

  @@index([projectId])
}

// Every assignment Calendar entry/Member.
// Linked by userId and calendarEvent (which contains a unique projectId value)
model CalendarAssignee {
  id            String        @id @default(uuid())
  userId        String
  calId         String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarEvent CalendarEvent @relation(fields: [calId], references: [id], onDelete: Cascade)

  @@unique([userId, calId])
  @@index([userId])
  @@index([calId])
}

// Every Calendar entry of every project
// Linked by a unique projectId value
model CalendarEvent {
  id          String             @id @default(uuid())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  projectId   String
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  startAt     DateTime
  endAt       DateTime
  categoryId  String?
  category    CalendarCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  description String?
  notes       String?
  assignees   CalendarAssignee[]

  @@index([projectId])
  @@index([categoryId])
}

// use an enum when you want to give the choice amongst a fixed set of values
enum DiscoveryBlockStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model DiscoveryBlock {
  id                  String               @id @default(uuid())
  projectId           String
  title               String
  description         String?
  icon                String? // at new section creation, you can pick an icon
  color               Int? // at new section creation, you can pick a card color - same
  // representation as TaskCategory.color/CalendarCategory.color:
  // an index into a fixed palette defined on the frontend
  status              DiscoveryBlockStatus @default(NOT_STARTED)
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  discoveryBlockItems DiscoveryBlockItem[] // one DiscoveryBlock => many DiscoveryBlockItem

  @@index([projectId])
}

model DiscoveryBlockItem {
  id               String         @id @default(uuid())
  discoveryBlockId String
  label            String
  isChecked        Boolean        @default(false)
  order            Int // position of the item in the list, updated when user reorders
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  discoveryBlock   DiscoveryBlock @relation(fields: [discoveryBlockId], references: [id], onDelete: Cascade)

  @@index([discoveryBlockId])
}

model EvaluationChecklistItem {
  id        String   @id @default(uuid())
  projectId String
  label     String
  isChecked Boolean  @default(false)
  order     Int // position of the item in the list, updated when user reorders
  section   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
