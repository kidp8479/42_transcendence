# ============================================================
# Database
# ============================================================
POSTGRES_USER=taskrabbit
POSTGRES_PASSWORD=changeme
POSTGRES_DB=taskrabbit
DATABASE_URL=postgresql://taskrabbit:changeme@db:5432/taskrabbit

# ============================================================
# Auth
# ============================================================
APP_ORIGIN=http://localhost:8080
AUTH_INTERNAL_TOKEN=change_this_internal_token_at_least_32_chars
AUTH_SESSION_COOKIE=tr_session
AUTH_CSRF_COOKIE=tr_csrf
AUTH_COOKIE_SECURE=false
AUTH_SESSION_IDLE_TIMEOUT=30m
AUTH_SESSION_ABSOLUTE_TIMEOUT=168h

# 2FA
TOTP_ISSUER=TaskRabbit

# OAuth — 42
OAUTH_42_CLIENT_ID=
OAUTH_42_CLIENT_SECRET=

# OAuth — Google
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# OAuth — GitHub (reserved for a future provider)
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# ============================================================
# Services (internal Docker network URLs)
# ============================================================
AUTH_SERVICE_URL=http://auth:3001

# ============================================================
# Frontend (exposed to the browser — use public hostname in prod)
# ============================================================
VITE_API_URL=http://localhost:8080/api
VITE_WS_URL=ws://localhost:8080/ws
